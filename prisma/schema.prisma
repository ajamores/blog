// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum postStatus {
  PUBLISHED
  DRAFT
}

model Admin {
  id       String @id @default(uuid())
  username String @unique
  password String
}

model Post {
  id        String     @id @default(uuid()) @db.Uuid
  slug      String     @unique
  title     String
  excerpt   String
  content   Json?
  status    postStatus @default(DRAFT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  //Posts can have many post categories
  postCategories Post_Category[]
}

model Category {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  //categoires can belong to many posts
  postCategories Post_Category[]
}

model Post_Category {
  id          String @id @default(uuid()) @db.Uuid
  post_id     String @db.Uuid
  category_id String @db.Uuid

  //Post_Category belongs to 1 post, if deleted deletes row here
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  //Post_Category belongs to 1 category, if deleted deletes row here
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  //Prevent duplicate tags on a post
  @@unique([post_id, category_id])
}
